{
    "name": "myde",
    "version": "0.0.1",
    "description": "my desktop",
    "main": "./out/main/main.js",
    "scripts": {
        "pack": "npm run build && electron-builder --dir -c electron-builder.config.js",
        "dist": "npm run build && electron-builder -p never -c electron-builder.config.js",
        "start": "electron-vite --ignoreConfigWarning preview",
        "dev": "electron-vite --ignoreConfigWarning dev",
        "build": "electron-vite --ignoreConfigWarning build",
        "build:remote-connect": "cd src/remote_connect && pnpm build",
        "desktop": "cd desktop && npm run build && cd .. && export desktop='desktop' && electron-vite --ignoreConfigWarning preview",
        "remote": "cd remote && npm run build && cd .. && export desktop='remote' && export nodeModule='on' && electron-vite --ignoreConfigWarning preview"
    },
    "author": {
        "name": "xsf",
        "email": "xushengfeng_zg@163.com"
    },
    "homepage": "https://github.com/xushengfeng/myde/",
    "license": "AGPL-3.0-only",
    "dependencies": {
        "dkh-ui": "^0.14.2",
        "ini": "^5.0.0",
        "myde-dbus": "^0.2.0",
        "myde-unix-socket": "^0.2.1",
        "noise-handshake": "^4.2.0",
        "noise-protocol": "^3.0.2",
        "peerjs": "^1.5.5",
        "spake2": "^1.0.2",
        "xml2js": "^0.6.2"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.4",
        "@types/ini": "^4.1.1",
        "@types/xml2js": "^0.4.14",
        "electron": "^41.1.0",
        "electron-builder": "^24.4.0",
        "electron-vite": "^4.0.1",
        "typescript": "^6.0.2",
        "vite": "^7.1.7",
        "vitest": "^4.1.0"
    }
}
