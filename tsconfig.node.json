{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "sourceMap": false,
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": false,
    "noImplicitReturns": true,
    "composite": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "electron.vite.config.*",
    "src/main/*",
    "src/preload/*",
    "src/desktop-api.ts",
    "src/connect/**/*.ts",
    "src/sys_api/**/*.ts",
    "src/setting/**/*.ts",
    "src/wayland/**/*.ts",
    "src/test_runner/**/*.ts",
    "src/input_map/**/*.ts",
    "src/input_codes/**/*.ts",
    "src/remote_connect/**/*.ts",
    "src/vite-env.d.ts",
    "lib/**/*.ts"
  ]
}