{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "sourceMap": false,
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": false,
    "noImplicitReturns": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "*.ts",
    "apps/**/*.ts",
    "../../src/desktop-api.ts",
    "../../src/event-emitter/**/*.ts",
    "../../src/sys_api/**/*.ts",
    "../../src/wayland/**/*.ts",
    "../../src/connect/**/*.ts",
    "../../src/setting/**/*.ts",
    "../../src/input_map/**/*.ts"
  ]
}
